# Copy to .env and fill in real values (never commit .env)

# Supabase PostgreSQL — Project Settings → Database → Connection string (URI)
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"

# Auth.js
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth (optional)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Resend — registration OTP + password reset (auto-enabled when configured)
# API key: https://resend.com/api-keys
RESEND_API_KEY=""
# Verified sender — use onboarding@resend.dev for testing, or your domain email in production
RESEND_FROM_EMAIL="onboarding@resend.dev"
# RESEND_FROM_NAME="Bravio"
# RESEND_TEST_TO="you@example.com"
# Set to "false" to skip OTP registration even when Resend is configured
# EMAIL_VERIFICATION_ENABLED="false"

# Paystack — paid course enrollment (auto-enabled when PAYSTACK_SECRET_KEY is set)
# Test keys: https://dashboard.paystack.com/#/settings/developer
PAYSTACK_SECRET_KEY=""
PAYSTACK_CURRENCY="GHS"
# Set to "false" to keep free enrollment even when a key is present (e.g. staging)
# PAYMENTS_ENABLED="false"

# Cloudinary (optional)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
