# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# Microsoft Office lock/temp files
~$*
~WRL*.tmp

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — never commit secrets (.env.example is tracked via negation below)
.env
.env.*
!.env.example

# third-party HTML templates (may contain embedded API keys)
.reference/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/app/generated/prisma

# instructor verification uploads
/public/uploads/selfies/
/public/uploads/course-thumbnails/

# private lesson PDFs (served via authenticated API)
/storage/lesson-pdfs/
